# Server
PORT=3000
NODE_ENV=development

# MongoDB  (free tier)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/memotap

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# Gemini API Keys (comma-separated for automatic rotation when quota is exhausted)
# Example with multiple keys: key1,key2,key3
GEMINI_API_KEYS=your-gemini-api-key

# Gemini Model (must support audio input)
# Options: gemini-2.5-flash, gemini-2.5-pro, gemini-2.5-flash-lite
GEMINI_MODEL=gemini-2.5-flash

# S3-compatible storage (optional)
# Accepts either a full URL or host, for example:
# S3_API_HOST=https://s3.amazonaws.com
# S3_API_HOST=nyc3.digitaloceanspaces.com
S3_API_HOST=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1

# Optional defaults used by the storage service
S3_BUCKET=
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=false
